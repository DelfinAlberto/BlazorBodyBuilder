@page "/home"
@layout MainLayout 
@inject NavigationManager Navigation

<!-- CONTENEDOR PRINCIPAL: Centrado en PC y fluido al 100% en móviles -->
<div class="w-full max-w-md mx-auto flex flex-col gap-6 text-slate-100 pb-28 select-none">
    
    <!-- 1. ENCABEZADO: Saludo al atleta -->
    <div class="flex items-center justify-between pt-4 px-1">
        <div class="flex flex-col">
            <h1 class="text-3xl font-black tracking-tighter text-white uppercase font-display leading-none">
                Hola Camila
            </h1>
            <p class="text-xs italic font-medium text-slate-400 mt-1">¿Ya entrenaste hoy?</p>
        </div>
    </div>

    <!-- 2. TARJETA DE PERFIL (Estilo nativo iOS/Android) -->
    <div class="w-full bg-white rounded-2xl p-4 flex items-center justify-between shadow-lg text-slate-900">
        <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full border-2 border-amber-500 overflow-hidden shrink-0">
                <img src="images/avatar-camila.png" class="w-full h-full object-cover" alt="Perfil" />
            </div>
            <div class="flex flex-col">
                <span class="font-extrabold text-sm tracking-tight">Camila Sosa</span>
                <span class="mt-0.5 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-500/10 text-amber-600 border border-amber-500/20 uppercase tracking-wider w-max">
                    👑 Socio
                </span>
            </div>
        </div>
        <button class="text-slate-400 hover:text-slate-600 cursor-pointer">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        </button>
    </div>

    <!-- 3. SECCIÓN: Rutina semanal con calce milimétrico de la pestaña colgante -->
    <!-- 3. SECCIÓN: Rutina semanal estructurada en 2 columnas perfectas (Estilo Captura) -->
    <div class="flex flex-col gap-2 relative px-1">
        <div class="flex items-center justify-between">
            <div class="flex flex-col">
                <h2 class="text-sm font-black text-white uppercase tracking-wide">Tu rutina semanal</h2>
                <p class="text-xs text-slate-400 italic">Para prevenir lesiones</p>
            </div>
            <!-- Botón flotante IA del Robot -->
            <div class="w-10 h-8 rounded-l-xl bg-amber-500 flex items-center justify-center text-slate-950 shadow-md cursor-pointer absolute -right-5 top-1 z-20">
                🤖
            </div>
        </div>

        <!-- CONTENEDOR DE LA RUTINA: Dividido en una grilla de 12 columnas para un control milimétrico -->
        <div class="w-full bg-white rounded-2xl p-4 grid grid-cols-12 gap-4 shadow-lg text-slate-900 relative overflow-visible mt-1 items-center">

            <!-- ========================================================================= -->
            <!-- COLUMNA IZQUIERDA (Ocupa 5 de 12 espacios de la grilla)                   -->
            <!-- ========================================================================= -->
            <div class="col-span-5 flex flex-col items-center justify-center border-r border-slate-100 pr-2">
                <!-- Círculo de gran tamaño (Calibrado a tu escala ideal) -->
                <div class="relative w-28 h-28 rounded-full border-2 border-slate-200 flex flex-col items-center justify-center bg-slate-50/50">
                    <!-- Anillo grueso de progreso amarillo -->
                    <div class="absolute inset-0 rounded-full border-[7px] border-amber-500 border-t-transparent border-r-transparent -rotate-45"></div>
                    <span class="text-3xl font-black tracking-tighter text-slate-800 leading-none">2/3</span>
                </div>
                <!-- Texto inferior alineado en la misma columna izquierda -->
                <span class="text-xs font-extrabold text-slate-500 text-center leading-tight mt-3 uppercase tracking-wider">
                    Sesiones<br />completadas
                </span>
            </div>

            <!-- ========================================================================= -->
            <!-- COLUMNA DERECHA (Ocupa 7 de 12 espacios de la grilla)                     -->
            <!-- ========================================================================= -->
            <div class="col-span-7 flex flex-col gap-4 w-full h-full justify-between pt-1">

                <!-- Sub-bloque 1: Calendario Semanal Horizontal con Pestaña Colgante -->
                <div class="flex w-full justify-between gap-1.5 text-center items-end relative h-12 pr-1 select-none">

                    <!-- Lunes (Completado con tilde celeste) -->
                    <div class="flex flex-col items-center min-w-[16px]">
                        <span class="text-[9px] text-cyan-500 font-bold leading-none mb-0.5">✓</span>
                        <span class="text-[9px] text-slate-400 font-extrabold leading-none">LU</span>
                        <span class="text-[11px] font-black text-slate-800 mt-0.5">8</span>
                    </div>

                    <!-- Martes -->
                    <div class="flex flex-col items-center min-w-[16px]">
                        <span class="text-[9px] text-transparent font-bold leading-none mb-0.5">✓</span>
                        <span class="text-[9px] text-slate-400 font-extrabold leading-none">MA</span>
                        <span class="text-[11px] font-black text-slate-800 mt-0.5">9</span>
                    </div>

                    <!-- Miércoles (Completado con tilde celeste) -->
                    <div class="flex flex-col items-center min-w-[16px]">
                        <span class="text-[9px] text-cyan-500 font-bold leading-none mb-0.5">✓</span>
                        <span class="text-[9px] text-slate-400 font-extrabold leading-none">MI</span>
                        <span class="text-[11px] font-black text-slate-800 mt-0.5">10</span>
                    </div>

                    <!-- Jueves -->
                    <div class="flex flex-col items-center min-w-[16px]">
                        <span class="text-[9px] text-transparent font-bold leading-none mb-0.5">✓</span>
                        <span class="text-[9px] text-slate-400 font-extrabold leading-none">JU</span>
                        <span class="text-[11px] font-black text-slate-800 mt-0.5">11</span>
                    </div>

                    <!-- VIERNES: PESTAÑA COLGANTE NATIVA (Se ajusta perfectamente a la sub-columna derecha) -->
                    <div class="absolute top-[-20px] bottom-[-2px] bg-slate-800 text-white rounded-b-xl w-[26px] flex flex-col items-center justify-center pt-1.5 shadow-md z-10 border-x border-b border-slate-700/30" style="left: calc(56%);">
                        <span class="text-[8px] text-amber-400 font-black tracking-tight leading-none">VI</span>
                        <span class="text-xs font-black tracking-tight mt-0.5 leading-none">12</span>
                    </div>

                    <!-- Espacio de reserva para el Viernes -->
                    <div class="flex flex-col items-center min-w-[26px]"></div>

                    <!-- Sábado -->
                    <div class="flex flex-col items-center min-w-[16px]">
                        <span class="text-[9px] text-transparent font-bold leading-none mb-0.5">✓</span>
                        <span class="text-[9px] text-slate-400 font-extrabold leading-none">SA</span>
                        <span class="text-[11px] font-black text-slate-800 mt-0.5">13</span>
                    </div>

                    <!-- Domingo -->
                    <div class="flex flex-col items-center min-w-[16px]">
                        <span class="text-[9px] text-transparent font-bold leading-none mb-0.5">✓</span>
                        <span class="text-[9px] text-slate-400 font-extrabold leading-none">DO</span>
                        <span class="text-[11px] font-black text-slate-800 mt-0.5">14</span>
                    </div>
                </div>

                <!-- Sub-bloque 2: Botonera y Registro compactados en la columna derecha -->
                <div class="flex flex-col items-center gap-2 w-full mt-2">
                    <button class="w-full h-10 bg-amber-500 hover:bg-amber-600 active:scale-[0.98] transition-all text-slate-950 font-black text-xs tracking-wider uppercase rounded-full shadow-md flex items-center justify-center cursor-pointer">
                        Entrenar Ahora
                    </button>

                    <button class="flex items-center justify-center gap-1.5 text-[11px] font-bold text-slate-500 hover:text-slate-700 transition-colors cursor-pointer py-0.5 w-full">
                        <span class="w-3.5 h-3.5 border border-slate-400 rounded-sm flex items-center justify-center text-[9px] font-black text-slate-500 bg-transparent pb-0.5">+</span>
                        Registrar entrenamiento
                    </button>
                </div>

            </div>

        </div>
    </div>


    <!-- 4. SECCIÓN: Tus logros (Mosaico de 3 columnas) -->
    <div class="flex flex-col gap-2 mt-4">
        <h2 class="text-sm font-black text-white uppercase tracking-wide px-1">Tus logros</h2>

        <div class="grid grid-cols-3 gap-2.5">
            <div class="bg-white rounded-2xl p-3 flex flex-col justify-between shadow-md text-slate-900 min-h-[110px]">
                <div class="flex items-center justify-between">
                    <span class="text-2xl font-black text-emerald-600 tracking-tight">10</span>
                    <span class="text-base">🏆</span>
                </div>
                <span class="text-[10px] font-bold text-slate-500 leading-tight">Objetivos<br />cumplidos</span>
            </div>

            <div class="bg-yellow-500 rounded-2xl p-3 flex flex-col justify-between shadow-md text-slate-950 min-h-[110px]">
                <div class="flex items-center justify-between">
                    <span class="text-2xl font-black tracking-tight">54</span>
                    <span class="text-base">🏋️‍♂️</span>
                </div>
                <span class="text-[10px] font-black leading-tight">Sesiones<br />terminadas</span>
            </div>

            <div class="bg-white rounded-2xl p-3 flex flex-col justify-between shadow-md text-slate-900 min-h-[110px]">
                <div class="flex items-center justify-between">
                    <span class="text-2xl font-black text-indigo-600 tracking-tight">43</span>
                    <span class="text-base">⏱️</span>
                </div>
                <span class="text-[10px] font-bold text-slate-500 leading-tight">Horas<br />entrenadas</span>
            </div>
        </div>
    </div>

    <!-- 5. SECCIÓN: Carrusel inferior híbrido (Diseño revista B&N) -->
    <div class="flex flex-col gap-3 mt-2">
        <h2 class="text-sm font-black text-white uppercase tracking-wide px-1">Contenido que te puede interesar</h2>

        <!-- Contenedor con Scroll Táctil Horizontal -->
        <div class="flex gap-4 overflow-x-auto pb-4 px-1 scrollbar-none snap-x touch-pan-x">

            <!-- TARJETA REVISTA 1 -->
            <div class="w-[155px] bg-white rounded-2xl overflow-hidden shadow-xl flex flex-col shrink-0 snap-start text-slate-900 border border-slate-100">
                <div class="w-full h-24 bg-slate-900 overflow-hidden">
                    <img src="images/gym-cardio.jpg" class="w-full h-full object-cover grayscale brightness-90 contrast-110" alt="Sobrecarga" />
                </div>
                <div class="p-3 flex flex-col justify-between flex-1 gap-2.5">
                    <div class="flex flex-col gap-0.5">
                        <h4 class="text-xs font-black leading-tight tracking-tight text-slate-900 uppercase">Sobrecarga progresiva:</h4>
                        <p class="text-[10px] font-medium text-slate-400 leading-tight">El principio detrás del progreso.</p>
                    </div>
                    <button class="w-max px-3 py-1 bg-slate-800 text-white font-black text-[9px] tracking-wider uppercase rounded-full active:scale-95 transition-transform cursor-pointer">
                        Saber +
                    </button>
                </div>
            </div>

            <!-- TARJETA REVISTA 2 -->
            <div class="w-[155px] bg-white rounded-2xl overflow-hidden shadow-xl flex flex-col shrink-0 snap-start text-slate-900 border border-slate-100">
                <div class="w-full h-24 bg-slate-900 overflow-hidden">
                    <img src="images/gym-cardio.jpg" class="w-full h-full object-cover grayscale brightness-90 contrast-110" alt="Sobrecarga" />
                </div>
                <div class="p-3 flex flex-col justify-between flex-1 gap-2.5">
                    <div class="flex flex-col gap-0.5">
                        <h4 class="text-xs font-black leading-tight tracking-tight text-slate-900 uppercase">Sobrecarga progresiva:</h4>
                        <p class="text-[10px] font-medium text-slate-400 leading-tight">El principio detrás del progreso.</p>
                    </div>
                    <button class="w-max px-3 py-1 bg-slate-800 text-white font-black text-[9px] tracking-wider uppercase rounded-full active:scale-95 transition-transform cursor-pointer">
                        Saber +
                    </button>
                </div>
            </div>

            <!-- TARJETA REVISTA 3 -->
            <div class="w-[155px] bg-white rounded-2xl overflow-hidden shadow-xl flex flex-col shrink-0 snap-start text-slate-900 border border-slate-100">
                <div class="w-full h-24 bg-slate-900 overflow-hidden">
                    <img src="images/gym-cardio.jpg" class="w-full h-full object-cover grayscale brightness-90 contrast-110" alt="Sobrecarga" />
                </div>
                <div class="p-3 flex flex-col justify-between flex-1 gap-2.5">
                    <div class="flex flex-col gap-0.5">
                        <h4 class="text-xs font-black leading-tight tracking-tight text-slate-900 uppercase">Sobrecarga progresiva:</h4>
                        <p class="text-[10px] font-medium text-slate-400 leading-tight">El principio detrás del progreso.</p>
                    </div>
                    <button class="w-max px-3 py-1 bg-slate-800 text-white font-black text-[9px] tracking-wider uppercase rounded-full active:scale-95 transition-transform cursor-pointer">
                        Saber +
                    </button>
                </div>
            </div>

        </div>
    </div>

</div>
