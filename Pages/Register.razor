@page "/register"
@layout NoMenuLayout
@inject NavigationManager Navigation

<div class="relative h-screen w-full bg-slate-950 overflow-hidden select-none">

    <!-- 1. CAPA DE FONDO (Fija detrás) -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <!-- 1. Imagen base: Se duplicó la visibilidad (opacity-55) y se subió el brillo -->
        <img src="images/background-gym.jpg" class="absolute inset-0 w-full h-full object-cover opacity-55 blur-[0.5px] brightness-110 contrast-100" alt="Gym Background" />

        <!-- 2. Filtro Verde Oliva Dorado: Más suave y luminoso -->
        <div class="absolute inset-0" style="background-color: #8a8a15; mix-blend-mode: multiply; opacity: 0.45;"></div>

        <!-- 3. Gradiente suavizado: Deja pasar la luz en el centro y arriba, oscurece sutilmente la base -->
        <div class="absolute inset-0" style="background-image: linear-gradient(to bottom, rgba(2, 6, 23, 0.1) 0%, rgba(2, 6, 23, 0.3) 50%, rgba(2, 6, 23, 0.75) 100%);"></div>
    </div>


    <!-- 2. CAPA DE CONTENIDO: Todo el bloque sube unificado en 4 segundos -->
  <!-- 2. CAPA DE CONTENIDO: Sube unificada en 4 segundos y se mantiene perfectamente centrada en PC y Móvil -->
<div class="absolute inset-0 z-10 flex flex-col justify-start pb-0 safe-top safe-bottom animate-slide-up-slow">
    
    <!-- CONTENEDOR DE SEGURIDAD: Limita el ancho en PC (max-w-md) y centra todo el bloque (mx-auto) -->
    <div class="w-full max-w-md mx-auto h-full flex flex-col justify-start">
        
        <!-- Bloque Superior: Ahora alineado milimétricamente con la tarjeta blanca en PC y móvil -->
        <div class="px-6 flex flex-col gap-2 mt-auto mb-4 w-full">
            <div class="w-14 h-14">
                <img src="images/logo-bodybuilders.png" class="w-full h-full object-contain" alt="Logo" />
            </div>
            <div>
                <p class="text-amber-500 text-[11px] italic font-semibold tracking-wide uppercase">Da el primer paso</p>
                <h1 class="text-3xl font-black tracking-tight text-white uppercase font-sans leading-none">Creá tu cuenta</h1>
            </div>
        </div>

        <!-- Bloque Inferior: Tarjeta Blanca asentada en la base -->
        <div class="w-full bg-white rounded-t-[32px] px-6 pt-7 pb-6 flex flex-col gap-4 shadow-2xl text-slate-900 shrink-0">
            
            <!-- Nombre y Apellido -->
            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-0.5">
                    <label class="text-[11px] font-bold text-slate-800 tracking-wide uppercase">Nombre</label>
                    <input type="text" placeholder="Tu primer nombre" class="w-full pb-1 text-sm font-medium border-b border-slate-300 focus:border-amber-500 outline-none transition-colors placeholder:text-slate-400 bg-transparent" />
                </div>
                <div class="flex flex-col gap-0.5">
                    <label class="text-[11px] font-bold text-slate-800 tracking-wide uppercase">Apellido</label>
                    <input type="text" placeholder="Tu apellido" class="w-full pb-1 text-sm font-medium border-b border-slate-300 focus:border-amber-500 outline-none transition-colors placeholder:text-slate-400 bg-transparent" />
                </div>
            </div>

            <!-- E-mail -->
            <div class="flex flex-col gap-0.5">
                <label class="text-[11px] font-bold text-slate-800 tracking-wide uppercase">E-mail</label>
                <input type="email" placeholder="Ingresá tu correo electrónico" class="w-full pb-1 text-sm font-medium border-b border-slate-300 focus:border-amber-500 outline-none transition-colors placeholder:text-slate-400 bg-transparent" />
            </div>

            <!-- Contraseña -->
            <div class="flex flex-col gap-0.5 relative">
                <label class="text-[11px] font-bold text-slate-800 tracking-wide uppercase">Contraseña</label>
                <div class="relative w-full">
                    <input type="@(verPassword ? "text" : "password")" placeholder="Creá tu clave de ingreso" class="w-full pb-1 pr-8 text-sm font-medium border-b border-slate-300 focus:border-amber-500 outline-none transition-colors placeholder:text-slate-400 bg-transparent" />
                    <button type="button" @onclick="TogglePassword" class="absolute right-0 bottom-1 text-amber-500 hover:text-amber-600 cursor-pointer">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                    </button>
                </div>
                <span class="text-[10px] text-slate-400 mt-0.5">*Al menos 8 caracteres con letras y números.</span>
            </div>

            <!-- Botón Crear Cuenta -->
            <button @onclick="RegistrarUsuario" class="w-full h-12 bg-amber-500 hover:bg-amber-600 active:scale-[0.98] transition-all duration-150 text-slate-950 font-black text-xs tracking-widest uppercase rounded-full shadow-lg shadow-amber-500/10 flex items-center justify-center cursor-pointer mt-1">
                Crear mi cuenta
            </button>

            <!-- Botón Volver -->
            <button @onclick="IrAlLogin" class="text-xs font-bold text-slate-500 hover:text-slate-700 text-center tracking-wide transition-colors cursor-pointer">
                Ya tengo una cuenta / Soy socio
            </button>
        </div>
        
    </div>
</div>

</div>

@code {
    private bool verPassword = false;
    private void TogglePassword() => verPassword = !verPassword;
    private void RegistrarUsuario() => Navigation.NavigateTo("/home");
    private void IrAlLogin() => Navigation.NavigateTo("/");
}
