@inherits LayoutComponentBase

<div class="relative h-screen w-full bg-slate-950 text-slate-50 antialiased font-sans overflow-hidden select-none">
    
    <!-- ========================================================================= -->
    <!-- CAPA DE FONDO FIJA: Compartida por todas las páginas internas de la App   -->
    <!-- ========================================================================= -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <!-- 1. Imagen base: Se duplicó la visibilidad (opacity-55) y se subió el brillo -->
        <img src="images/background-gym.jpg" class="absolute inset-0 w-full h-full object-cover opacity-55 blur-[0.5px] brightness-110 contrast-100" alt="Gym Background" />

        <!-- 2. Filtro Verde Oliva Dorado: Más suave y luminoso -->
        <div class="absolute inset-0" style="background-color: #8a8a15; mix-blend-mode: multiply; opacity: 0.45;"></div>

        <!-- 3. Gradiente suavizado: Deja pasar la luz en el centro y arriba, oscurece sutilmente la base -->
        <div class="absolute inset-0" style="background-image: linear-gradient(to bottom, rgba(2, 6, 23, 0.1) 0%, rgba(2, 6, 23, 0.3) 50%, rgba(2, 6, 23, 0.75) 100%);"></div>
    </div>

    <!-- ========================================================================= -->
    <!-- CAPA DE INTERFAZ: Menús y contenido que se deslizan sobre el fondo        -->
    <!-- ========================================================================= -->
    <div class="relative z-10 flex flex-col h-full w-full">
        
        <!-- Encabezado Superior Fijo (Top Bar Esmerilado) -->
        <header class="h-14 bg-slate-900/50 backdrop-blur-md border-b border-slate-800/40 flex items-center justify-between px-4 shrink-0 safe-top">
            <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-amber-500 to-amber-600 flex items-center justify-center shadow-lg shadow-amber-500/10">
                    <span class="text-xs font-black tracking-tighter text-slate-950">B</span>
                </div>
                <span class="text-sm font-black tracking-tight text-white uppercase font-sans">BodyBuilder</span>
            </div>
            
            <!-- Isla / Píldora de Estado -->
            <span class="px-2.5 py-0.5 text-[10px] font-bold bg-emerald-500/10 text-emerald-400 rounded-full border border-emerald-500/20 flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
                Offline
            </span>
        </header>

        <!-- Contenedor Principal con Scroll Táctil e Independiente -->
        <main class="flex-1 overflow-y-auto pb-24 px-4 pt-2 -webkit-overflow-scrolling-touch scrollbar-none">
            @Body
        </main>

        <!-- Barra de Navegación Inferior Fija (Bottom Tab Bar Esmerilada) -->
        <nav class="fixed bottom-0 left-0 right-0 h-16 bg-slate-900/60 backdrop-blur-lg border-t border-slate-800/40 flex items-center justify-around px-2 safe-bottom z-50">
            <NavLink href="home" Match="NavLinkMatch.All" class="flex flex-col items-center justify-center flex-1 py-2 text-slate-400 transition-colors" activeClass="text-amber-500 font-bold">
                <svg class="w-5 h-5 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <span class="text-[10px] tracking-tight uppercase font-sans">Inicio</span>
            </NavLink>

            <NavLink href="entrenar" class="flex flex-col items-center justify-center flex-1 py-2 text-slate-400 transition-colors" activeClass="text-amber-500 font-bold">
                <svg class="w-5 h-5 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <span class="text-[10px] tracking-tight uppercase font-sans">Entrenar</span>
            </NavLink>

            <NavLink href="historial" class="flex flex-col items-center justify-center flex-1 py-2 text-slate-400 transition-colors" activeClass="text-amber-500 font-bold">
                <svg class="w-5 h-5 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
                <span class="text-[10px] tracking-tight uppercase font-sans">Bitácora</span>
            </NavLink>
        </nav>
        
    </div>
</div>
